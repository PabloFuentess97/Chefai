# ---- App ----
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://chefai.fit
APP_URL=https://chefai.fit
BRAND_NAME=ChefAI
SUPPORT_EMAIL=hola@chefai.fit

# ---- Database ----
DATABASE_URL=postgresql://chefai:chefai@localhost:5432/chefai?schema=public
POSTGRES_USER=chefai
POSTGRES_PASSWORD=chefai
POSTGRES_DB=chefai

# ---- Auth ----
JWT_SECRET=replace-with-openssl-rand-base64-48
SESSION_COOKIE_NAME=session
SESSION_TTL_DAYS=30

# Admin seed — REQUIRED to change before deploying
# These are placeholders. Never deploy with these values; the seed will
# refuse to create the admin if ADMIN_PASSWORD matches the placeholder.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password-min-16-chars

# ---- AI providers ----
# Choose where text and image generation are routed.
# TEXT_PROVIDER:  "openai" | "gemini"
# IMAGE_PROVIDER: "openai" | "fal"
TEXT_PROVIDER=openai
IMAGE_PROVIDER=openai

# OpenAI (always required for the OPENAI_API_KEY env validation; can be a
# placeholder if you only use Gemini + Fal)
OPENAI_API_KEY=sk-replace-me
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Gemini (used when TEXT_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.0-flash

# Fal.ai (used when IMAGE_PROVIDER=fal)
FAL_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/dev

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ---- PayPal ----
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=replace-me
PAYPAL_CLIENT_SECRET=replace-me
PAYPAL_WEBHOOK_ID=replace-me

# ---- Email ----
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM="ChefAI <hola@chefai.fit>"

# ---- Redis (background jobs) ----
# Optional. If unset, image generation runs inline (slower for meal plans).
REDIS_URL=redis://redis:6379

# ---- Storage ----
# Path relative to project root. In Docker we mount a volume here.
UPLOADS_DIR=./public/uploads
