# ---- App ----
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://chefai.fit
APP_URL=https://chefai.fit
BRAND_NAME=ChefAI
SUPPORT_EMAIL=hola@chefai.fit

# ---- Database ----
DATABASE_URL=postgresql://chefai:chefai@localhost:5432/chefai?schema=public
POSTGRES_USER=chefai
POSTGRES_PASSWORD=chefai
POSTGRES_DB=chefai

# ---- Auth ----
JWT_SECRET=replace-with-openssl-rand-base64-48
SESSION_COOKIE_NAME=session
SESSION_TTL_DAYS=30

# Admin seed
ADMIN_EMAIL=admin@chefai.app
ADMIN_PASSWORD=ChangeMeNow1234!

# ---- OpenAI ----
OPENAI_API_KEY=sk-replace-me
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ---- PayPal ----
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=replace-me
PAYPAL_CLIENT_SECRET=replace-me
PAYPAL_WEBHOOK_ID=replace-me

# ---- Email ----
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM="ChefAI <hola@chefai.fit>"

# ---- Redis (background jobs) ----
# Optional. If unset, image generation runs inline (slower for meal plans).
REDIS_URL=redis://redis:6379

# ---- Storage ----
# Path relative to project root. In Docker we mount a volume here.
UPLOADS_DIR=./public/uploads
