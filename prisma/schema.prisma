// Prisma schema — ChefAI

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- AUTH ----------

enum Role {
  USER
  ADMIN
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String
  name            String?
  role            Role            @default(USER)
  emailVerifiedAt DateTime?
  verifyToken     String?         @unique
  resetToken      String?         @unique
  resetTokenExp   DateTime?
  preferredGoal   String?         // diet goal default: deficit | maintain | volume | definition | muscle
  dietaryProfile  String?         // dietary profile: omnivore | vegetarian | vegan | pescatarian | keto | lowcarb | glutenfree | lactosefree | paleo | mediterranean
  // ----- Campaign / trial -----
  campaignId      String?
  trialStartedAt  DateTime?
  trialEndsAt     DateTime?
  trialPlanId     String?         // plan to charge once the trial expires
  trialChargedAt  DateTime?       // when the auto-charge actually happened (success)
  stripeCustomerId String?        // saved Stripe customer id (set during signup w/ setup intent)
  stripePaymentMethodId String?   // default payment method saved at signup
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  sessions     Session[]
  subscription Subscription?
  recipes      Recipe[]
  history      RecipeHistory[]
  usage        UsageCounter[]
  payments     Payment[]
  mealPlans    MealPlan[]
  shoppingList ShoppingListItem[]
  campaign     Campaign?          @relation("CampaignUsers", fields: [campaignId], references: [id])
  trialPlan    Plan?              @relation("TrialPlan", fields: [trialPlanId], references: [id])

  @@index([email])
  @@index([createdAt])
  @@index([campaignId])
  @@index([trialEndsAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ---------- BILLING ----------

enum BillingInterval {
  MONTH
  YEAR
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MANUAL
}

model Plan {
  id              String          @id @default(cuid())
  slug            String          @unique
  name            String
  description     String?
  priceCents      Int
  currency        String          @default("EUR")
  interval        BillingInterval @default(MONTH)
  recipesPerMonth Int
  imagesEnabled   Boolean         @default(false)
  imageQuality    String          @default("low")
  pdfExport       Boolean         @default(false)
  cookbookExport  Boolean         @default(false)
  shoppingList    Boolean         @default(false)
  weeklyPlanner   Boolean         @default(false)
  mealPlanner     Boolean         @default(false)
  voiceCooking    Boolean         @default(false)
  fridgePhoto     Boolean         @default(false)
  substitutions   Boolean         @default(false)
  prioritySupport Boolean         @default(false)
  stripePriceId   String?
  paypalPlanId    String?
  isActive        Boolean         @default(true)
  isPublic        Boolean         @default(true)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  subscriptions Subscription[]
  campaigns     Campaign[]     @relation("CampaignTargetPlan")
  trialUsers    User[]         @relation("TrialPlan")

  @@index([slug])
  @@index([isActive, isPublic])
}

// ---------- CAMPAIGNS ----------
//
// External landing-page campaigns with custom URLs (e.g. /r/7dias-gratis).
// Each campaign defines a free trial (N days + N recipes/day) that converts
// into a subscription to `targetPlan` once the trial expires.

model Campaign {
  id                  String    @id @default(cuid())
  slug                String    @unique
  name                String
  description         String?
  // Visual template (preset: "trial-7days", "mothers-day", "black-friday", "christmas", ...)
  templateKey         String?
  accentColor         String?   // HEX override for the landing accent (defaults to brand)
  // Landing copy
  heroBadge           String?   // e.g. "7 dias gratis"
  heroTitle           String?
  heroSubtitle        String?
  heroImageUrl        String?
  ctaLabel            String?   // e.g. "Empezar gratis"
  bulletList          String?   // pipe-separated bullets ("Recetas IA|Foto nevera|Cocina por voz")
  customHtml          String?   // optional raw HTML override for the landing
  // Trial config
  trialDays           Int       @default(7)
  trialRecipesPerDay  Int       @default(5)
  targetPlanId        String
  // Lifecycle
  isActive            Boolean   @default(true)
  expiresAt           DateTime? // after this date, /r/<slug> stops accepting signups
  // Stats (denormalised counters; live aggregate also available)
  signupCount         Int       @default(0)
  conversionCount     Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  targetPlan Plan   @relation("CampaignTargetPlan", fields: [targetPlanId], references: [id])
  users      User[] @relation("CampaignUsers")

  @@index([slug])
  @@index([isActive])
  @@index([expiresAt])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  planId               String
  provider             PaymentProvider
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  paypalSubscriptionId String?            @unique
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([currentPeriodEnd])
}

model Payment {
  id          String          @id @default(cuid())
  userId      String
  provider    PaymentProvider
  externalId  String
  amountCents Int
  currency    String          @default("EUR")
  status      String
  rawPayload  Json?
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([userId])
  @@index([createdAt])
}

// ---------- RECIPES ----------

enum RecipeSource {
  AI_GENERATED
  USER_SAVED
}

model Recipe {
  id               String       @id @default(cuid())
  userId           String
  source           RecipeSource @default(AI_GENERATED)
  title            String
  description      String?
  servings         Int
  prepMinutes      Int?
  cookMinutes      Int?
  difficulty       String?
  cuisine          String?
  imageUrl         String?
  imageStoragePath String?
  totalCalories    Float?
  totalProteins    Float?
  totalFats        Float?
  totalCarbs       Float?
  promptHash       String?
  isFavorite       Boolean      @default(false)
  mealType         String?      // breakfast | lunch | snack | dinner — for meal plan reuse
  goal             String?      // deficit | maintain | volume | definition | muscle
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredients     RecipeIngredient[]
  steps           RecipeStep[]
  history         RecipeHistory[]
  mealPlanItems   MealPlanItem[]
  shoppingItems   ShoppingListItem[]

  @@index([userId, createdAt])
  @@index([promptHash])
  @@index([mealType, goal, difficulty])
}

model RecipeIngredient {
  id        String  @id @default(cuid())
  recipeId  String
  name      String
  quantity  Float
  unit      String
  optional  Boolean @default(false)
  suggested Boolean @default(false)
  calories  Float?
  proteins  Float?
  fats      Float?
  carbs     Float?
  sortOrder Int     @default(0)

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model RecipeStep {
  id          String @id @default(cuid())
  recipeId    String
  order       Int
  content     String @db.Text
  durationMin Int?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, order])
  @@index([recipeId])
}

model RecipeHistory {
  id           String   @id @default(cuid())
  userId       String
  recipeId     String
  promptInputs Json
  tokensUsed   Int?
  costCents    Int?
  createdAt    DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ---------- USAGE / LIMITS ----------

model UsageCounter {
  id          String   @id @default(cuid())
  userId      String
  periodKey   String
  recipesUsed Int      @default(0)
  imagesUsed  Int      @default(0)
  tokensUsed  Int      @default(0)
  costCents   Int      @default(0)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodKey])
  @@index([periodKey])
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(0)
  windowEnd DateTime
  updatedAt DateTime @updatedAt

  @@index([windowEnd])
}

// ---------- SETTINGS (BRANDING + GLOBAL) ----------

model Settings {
  id           Int      @id @default(1)
  brandName    String   @default("ChefAI")
  brandTagline String?
  brandLogoUrl String?
  brandColor   String   @default("#16a34a")
  supportEmail String   @default("hola@chefai.fit")
  termsUrl     String?
  privacyUrl   String?
  updatedAt    DateTime @updatedAt
}

// ---------- MEAL PLANS ----------

enum MealPlanType {
  DAILY
  WEEKLY
}

enum MealSlot {
  BREAKFAST
  LUNCH
  SNACK
  DINNER
}

model MealPlan {
  id         String       @id @default(cuid())
  userId     String
  type       MealPlanType
  startDate  DateTime
  goal       String?
  difficulty String?
  servings   Int          @default(1)
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MealPlanItem[]

  @@index([userId, startDate])
}

model MealPlanItem {
  id        String   @id @default(cuid())
  planId    String
  dayIndex  Int      // 0 for daily plans; 0-6 for weekly (Mon..Sun)
  slot      MealSlot
  recipeId  String
  servings  Int      @default(1)
  createdAt DateTime @default(now())

  plan   MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  recipe Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([planId, dayIndex, slot])
  @@index([planId])
  @@index([recipeId])
}

// ---------- SHOPPING LIST ----------

model ShoppingListItem {
  id        String   @id @default(cuid())
  userId    String
  name      String
  quantity  Float
  unit      String
  recipeId  String?  // optional source recipe
  isBought  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([userId, isBought, createdAt])
}
